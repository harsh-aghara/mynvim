-- require("nvchad.configs.lspconfig").defaults()
--
-- local servers = { "html", "cssls", "clangd", "pyright" }
-- vim.lsp.enable(servers)
--
-- read :h vim.lsp.config for changing options of lsp servers
-- ===================================================================
-- NvChad LSP Auto-Setup
-- This script automatically sets up all LSP servers installed via Mason
-- No need to manually edit the server list when you install a new one
-- ===================================================================

-- 1. Load NvChad's default LSP configuration
local nvlsp = require("nvchad.configs.lspconfig").defaults

-- These are helper functions and capabilities from NvChad
local on_attach = nvlsp.on_attach
local on_init = nvlsp.on_init
local capabilities = nvlsp.capabilities

-- 2. Require lspconfig and mason-lspconfig
-- lspconfig: core plugin for configuring LSP servers
-- mason-lspconfig: helps connect Mason-installed servers with lspconfig
local lspconfig = require("lspconfig")
local mason_lsp = require("mason-lspconfig")

-- 3. Debug: print a list of installed LSP servers from Mason
-- (You can comment this out once you confirm it works)
-- print("Mason LSPs detected:", vim.inspect(mason_lsp.get_installed_servers()))

-- 4. Loop through each installed server and set it up
for _, server in ipairs(mason_lsp.get_installed_servers()) do
    -- Basic setup options (common to all servers)
    local opts = {
        on_attach = on_attach,
        on_init = on_init,
        capabilities = capabilities,
    }

    -- 5. Special settings for certain servers (example: lua_ls)
    if server == "lua_ls" then
        opts.settings = {
            Lua = {
                diagnostics = { globals = { "vim" } }, -- Recognize 'vim' as a global
                workspace = {
                    library = {
                        vim.fn.expand("$VIMRUNTIME/lua"),
                        vim.fn.expand("$VIMRUNTIME/lua/vim/lsp"),
                        vim.fn.stdpath("data") .. "/lazy/ui/nvchad_types",
                        vim.fn.stdpath("data") .. "/lazy/lazy.nvim/lua/lazy",
                    },
                },
            },
        }
    end

    -- 6. Apply the configuration for this server
    lspconfig[server].setup(opts)
end
